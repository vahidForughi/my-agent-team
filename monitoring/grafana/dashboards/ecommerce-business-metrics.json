{
  "dashboard": {
    "id": null,
    "title": "E-Commerce Business Metrics",
    "tags": ["ecommerce", "business", "kpi", "revenue"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Revenue Overview",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(revenue_total)",
            "legendFormat": "Total Revenue"
          },
          {
            "expr": "sum(rate(revenue_total[1h]))",
            "legendFormat": "Revenue/hour"
          },
          {
            "expr": "sum(rate(revenue_total[1d]))",
            "legendFormat": "Revenue/day"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "mappings": [],
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 1000},
                {"color": "red", "value": 10000}
              ]
            },
            "unit": "currencyUSD"
          }
        },
        "gridPos": {"h": 8, "w": 16, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "Order Metrics",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(orders_total)",
            "legendFormat": "Total Orders"
          },
          {
            "expr": "sum(rate(orders_created_total[5m]))",
            "legendFormat": "Orders/min"
          },
          {
            "expr": "sum(rate(orders_completed_total[5m]))",
            "legendFormat": "Completed/min"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "mappings": [],
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 10},
                {"color": "red", "value": 100}
              ]
            },
            "unit": "orders"
          }
        },
        "gridPos": {"h": 8, "w": 8, "x": 16, "y": 0}
      },
      {
        "id": 3,
        "title": "Order Value Trends",
        "type": "timeseries",
        "targets": [
          {
            "expr": "avg(order_value)",
            "legendFormat": "Average Order Value"
          },
          {
            "expr": "histogram_quantile(0.95, order_value_bucket)",
            "legendFormat": "P95 Order Value"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "mappings": [],
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 100},
                {"color": "red", "value": 1000}
              ]
            },
            "unit": "currencyUSD"
          }
        },
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 8}
      },
      {
        "id": 4,
        "title": "Product Performance",
        "type": "table",
        "targets": [
          {
            "expr": "sum(product_views) by (product_id, product_name)",
            "legendFormat": "{{product_name}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "mappings": [],
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": null},
                {"color": "red", "value": null}
              ]
            },
            "unit": "views"
          },
          "overrides": [
            {
              "matcher": {
                "id": "byName",
                "options": "Value"
              },
              "properties": [
                {
                  "id": "custom.width",
                  "value": 150
                }
              ]
            }
          ]
        },
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16}
      },
      {
        "id": 5,
        "title": "Cart & Checkout Funnel",
        "type": "barchart",
        "targets": [
          {
            "expr": "sum(cart_additions)",
            "legendFormat": "Cart Additions"
          },
          {
            "expr": "sum(cart_checkouts)",
            "legendFormat": "Checkouts"
          },
          {
            "expr": "sum(orders_created)",
            "legendFormat": "Orders Created"
          },
          {
            "expr": "sum(orders_completed)",
            "legendFormat": "Orders Completed"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "mappings": [],
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": null},
                {"color": "red", "value": null}
              ]
            },
            "unit": "short"
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16}
      },
      {
        "id": 6,
        "title": "Conversion Rates",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(orders_created) / sum(cart_additions) * 100",
            "legendFormat": "Cart to Order %"
          },
          {
            "expr": "sum(orders_completed) / sum(orders_created) * 100",
            "legendFormat": "Order Completion %"
          },
          {
            "expr": "sum(product_purchases) / sum(product_views) * 100",
            "legendFormat": "Product Purchase %"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "mappings": [],
            "thresholds": {
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 1},
                {"color": "red", "value": 5}
              ]
            },
            "unit": "percent"
          }
        },
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 24}
      },
      {
        "id": 7,
        "title": "User Engagement",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(active_users)",
            "legendFormat": "Active Users"
          },
          {
            "expr": "avg(session_duration)",
            "legendFormat": "Avg Session Duration"
          },
          {
            "expr": "sum(page_views)",
            "legendFormat": "Page Views"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "mappings": [],
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 100},
                {"color": "red", "value": 1000}
              ]
            },
            "unit": "short"
          }
        },
        "gridPos": {"h": 8, "w": 8, "x": 8, "y": 24}
      },
      {
        "id": 8,
        "title": "Search Analytics",
        "type": "timeseries",
        "targets": [
          {
            "expr": "sum(search_queries)",
            "legendFormat": "Search Queries"
          },
          {
            "expr": "sum(search_results)",
            "legendFormat": "Search Results"
          },
          {
            "expr": "sum(search_clicks)",
            "legendFormat": "Search Clicks"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "mappings": [],
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": null},
                {"color": "red", "value": null}
              ]
            },
            "unit": "short"
          }
        },
        "gridPos": {"h": 8, "w": 8, "x": 16, "y": 24}
      },
      {
        "id": 9,
        "title": "Revenue by Category",
        "type": "piechart",
        "targets": [
          {
            "expr": "sum(revenue) by (category)",
            "legendFormat": "{{category}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "mappings": [],
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": null},
                {"color": "red", "value": null}
              ]
            },
            "unit": "currencyUSD"
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 32}
      },
      {
        "id": 10,
        "title": "Top Products by Revenue",
        "type": "table",
        "targets": [
          {
            "expr": "sum(product_revenue) by (product_id, product_name)",
            "legendFormat": "{{product_name}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "mappings": [],
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 1000},
                {"color": "red", "value": 10000}
              ]
            },
            "unit": "currencyUSD"
          },
          "overrides": [
            {
              "matcher": {
                "id": "byName",
                "options": "Value"
              },
              "properties": [
                {
                  "id": "custom.width",
                  "value": 150
                }
              ]
            }
          ]
        },
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 32}
      },
      {
        "id": 11,
        "title": "Hourly Sales Pattern",
        "type": "timeseries",
        "targets": [
          {
            "expr": "sum(rate(orders_created_total[1h])) by (hour)",
            "legendFormat": "Orders by Hour"
          },
          {
            "expr": "sum(rate(revenue_total[1h])) by (hour)",
            "legendFormat": "Revenue by Hour",
            "yAxis": 2
          }
        ],
        "fieldConfig": {
          "defaults": {
            "mappings": [],
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": null},
                {"color": "red", "value": null}
              ]
            }
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 40}
      },
      {
        "id": 12,
        "title": "Customer Satisfaction",
        "type": "stat",
        "targets": [
          {
            "expr": "avg(customer_satisfaction_score)",
            "legendFormat": "Satisfaction Score"
          },
          {
            "expr": "sum(customer_reviews)",
            "legendFormat": "Total Reviews"
          },
          {
            "expr": "avg(customer_rating)",
            "legendFormat": "Average Rating"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "mappings": [],
            "thresholds": {
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 3},
                {"color": "green", "value": 4}
              ]
            },
            "unit": "short"
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 40}
      }
    ],
    "time": {
      "from": "now-24h",
      "to": "now"
    },
    "refresh": "30s",
    "templating": {
      "list": [
        {
          "name": "timeRange",
          "type": "custom",
          "query": "1h, 6h, 24h, 7d, 30d",
          "current": {
            "selected": false,
            "text": "24h",
            "value": "24h"
          }
        },
        {
          "name": "category",
          "type": "query",
          "query": "label_values(category)",
          "refresh": 1,
          "includeAll": true,
          "allValue": ".*",
          "regex": "",
          "multi": true,
          "current": {
            "selected": false,
            "text": "All",
            "value": "$__all"
          }
        }
      ]
    },
    "links": [
      {
        "title": "Service Metrics Dashboard",
        "url": "/d/ecommerce-service-metrics",
        "target": "_blank"
      },
      {
        "title": "Performance Dashboard",
        "url": "/d/performance-overview",
        "target": "_blank"
      }
    ]
  }
}