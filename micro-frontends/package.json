{
  "name": "@ecommerce-micro-frontend/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "postinstall": "npm run build:packages",
    "build:packages": "npm run build:app-injector && npm run build:auth-provider && npm run build:shared-layout",
    "build:app-injector": "cd packages/app-injector && npm install && npm run build",
    "build:auth-provider": "cd packages/auth-provider && npm install && npm run build",
    "build:shared-layout": "cd packages/shared-layout && npm install && npm run build",
    "setup": "npm install && npm run build:packages",
    "start": "nx run-many --target=serve --projects=host,store,checkout,account,admin --parallel=5",
    "start:host": "nx serve host",
    "start:store": "nx serve store",
    "start:checkout": "nx serve checkout",
    "start:account": "nx serve account",
    "build": "nx run-many --target=build --all",
    "build:host": "nx build host",
    "build:prod": "nx run-many --target=build --configuration=production --all",
    "test": "nx run-many --target=test --all",
    "test:watch": "nx run-many --target=test --all --watch",
    "test:coverage": "nx run-many --target=test --all --coverage",
    "lint": "nx run-many --target=lint --all",
    "lint:fix": "nx run-many --target=lint --all --fix",
    "format": "nx format:write",
    "format:check": "nx format:check",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "affected:test": "nx affected --target=test",
    "affected:build": "nx affected --target=build",
    "affected:lint": "nx affected --target=lint",
    "graph": "nx graph",
    "clean": "nx reset && rm -rf packages/*/dist packages/*/node_modules"
  },
  "private": true,
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "@eslint/js": "^9.39.4",
    "@nx/eslint": "21.6.11",
    "@nx/eslint-plugin": "21.6.11",
    "@nx/jest": "21.6.11",
    "@nx/js": "21.6.11",
    "@nx/module-federation": "22.7.5",
    "@nx/playwright": "^22.7.5",
    "@nx/react": "^22.7.5",
    "@nx/web": "21.6.11",
    "@nx/webpack": "^22.7.5",
    "@nx/workspace": "21.6.11",
    "@playwright/test": "^1.60.0",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.6.2",
    "@svgr/webpack": "^8.0.1",
    "@swc-node/register": "~1.11.1",
    "@swc/cli": "~0.8.1",
    "@swc/core": "~1.15.40",
    "@swc/helpers": "~0.5.23",
    "@tanstack/router-cli": "^1.167.17",
    "@tanstack/router-plugin": "^1.168.18",
    "@testing-library/dom": "10.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.24",
    "@types/node": "^20.19.42",
    "@types/papaparse": "^5.5.2",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "antd-zod": "^6.1.0",
    "axios-mock-adapter": "^2.1.0",
    "babel-jest": "^30.4.1",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.35.0",
    "eslint-plugin-react-hooks": "5.2.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jest-environment-node": "^30.4.1",
    "jest-util": "^30.4.1",
    "nx": "21.6.11",
    "prettier": "^2.6.2",
    "react-refresh": "^0.18.0",
    "ts-jest": "^29.4.11",
    "ts-node": "10.9.2",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.60.1"
  },
  "dependencies": {
    "@ant-design/icons": "^5.5.2",
    "@azure/msal-browser": "^3.27.0",
    "@azure/msal-react": "^2.1.1",
    "@ecommerce-platform/auth-provider": "^1.2.6",
    "@ecommerce-platform/shared-layout": "^1.0.1",
    "@module-federation/enhanced": "^2.5.1",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-query-devtools": "^5.101.0",
