    "antd": "^5.22.6",
    "axios": "^1.17.0",
    "dayjs": "^1.11.21",
    "i18next": "^25.10.10",
    "lodash": "^4.18.1",
    "papaparse": "^5.5.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^16.6.6",
    "react-router-dom": "^6.30.4",
    "xlsx": "^0.18.5",
    "zod": "^3.24.4",
    "zustand": "^5.0.14"
  },
  "overrides": {
    "koa": "3.0.3",
    "picomatch": "^4.0.4"
  }
}
