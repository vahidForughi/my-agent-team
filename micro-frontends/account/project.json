{
  "name": "account",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "account/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/webpack:webpack",
      "outputs": [
        "{options.outputPath}"
      ],
      "defaultConfiguration": "production",
      "options": {
        "compiler": "babel",
        "outputPath": "dist/account",
        "index": "account/src/index.html",
        "baseHref": "/",
        "main": "account/src/main.ts",
        "tsConfig": "account/tsconfig.app.json",
        "assets": [
          "account/src/favicon.ico",
          "account/src/assets"
        ],
        "styles": [
          "account/src/styles.less"
        ],
        "scripts": [],
        "webpackConfig": "account/webpack.config.ts"
      },
      "configurations": {
        "development": {
          "extractLicenses": false,
          "optimization": false,
          "sourceMap": true,
          "vendorChunk": true
        },
        "production": {
          "fileReplacements": [
            {
              "replace": "account/src/environments/environment.ts",
              "with": "account/src/environments/environment.prod.ts"
            }
          ],
          "optimization": true,
          "outputHashing": "all",
          "sourceMap": false,
          "namedChunks": false,
          "extractLicenses": true,
          "vendorChunk": false,
          "webpackConfig": "account/webpack.config.prod.ts"
        }
      }
    },
    "serve": {
      "executor": "@nx/react:module-federation-dev-server",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "account:build",
        "hmr": true,
        "port": 4203
      },
      "configurations": {
        "development": {
          "buildTarget": "account:build:development"
        },
        "production": {
          "buildTarget": "account:build:production",
          "hmr": false
        }
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "serve-static": {
      "executor": "@nx/react:module-federation-static-server",
      "defaultConfiguration": "production",
      "options": {
        "serveTarget": "account:serve"
      },
      "configurations": {
        "development": {
          "serveTarget": "account:serve:development"
        },
        "production": {
          "serveTarget": "account:serve:production"
        }
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": [
        "{workspaceRoot}/coverage/{projectRoot}"
      ],
      "options": {
        "jestConfig": "account/jest.config.ts"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./node_modules/.bin/tsc --noEmit -p account/tsconfig.app.json",
        "cwd": "{workspaceRoot}/micro-frontends"
      }
    },
    "routes:generate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx @tanstack/router-cli generate",
        "cwd": "account"
      }
    },
    "routes:watch": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx @tanstack/router-cli watch",
        "cwd": "account"
      }
    }
  }
}
