    {
      "id": "US-002",
      "title": "Expose it through the API",
      "description": "As a client, I want an endpoint to read/write X so the UI can use it.",
      "acceptanceCriteria": [
        "New endpoint documented and wired through the gateway",
        "Contract tests pass",
        "Typecheck passes"
      ],
      "priority": 2,
      "passes": false,
      "notes": "Complex story — raised above the default 1: two independent backend sub-tasks plus a tester run concurrently. Optional `model` overrides defaults.model for this harder story; omit it (like US-001/US-003) to use the cheaper default tier.",
      "agents": [
        { "role": "backend-architect", "count": 2 },
        { "role": "api-tester", "count": 1 }
      ],
      "parallelism": 3,
      "model": "opus"
    },
    {
      "id": "US-003",
      "title": "Show it in the UI",
      "description": "As a user, I want to see X so I can act on it.",
      "acceptanceCriteria": [
        "Component renders X with loading/empty/error states",
        "Typecheck passes",
        "Verify in browser (screenshot for the progress log)"
      ],
      "priority": 3,
      "passes": false,
      "notes": "",
      "agents": [
