# ==================================================================
# Angular Client - Environment Configuration
# ==================================================================
# Copy this file to .env for local production builds
# For AWS Amplify deployment, set these in Amplify Console Environment Variables
# ==================================================================

# ==================================================================
# API Configuration
# ==================================================================
# Backend API Gateway URL
API_URL=http://localhost:8010

# ==================================================================
# Client Configuration
# ==================================================================
# Frontend application URL
CLIENT_URL=http://localhost:4200

# ==================================================================
# Identity Provider Configuration
# ==================================================================
# Identity Provider authority URL
IDP_AUTHORITY=https://localhost:9009

# ==================================================================
# Azure B2C Authentication (Optional)
# ==================================================================
# Azure B2C Client ID (Application ID from Azure portal)
AZURE_B2C_CLIENT_ID=d0dafab9-cae6-426d-a516-eab88853767c

# Azure B2C authority URL (includes tenant and user flow)
AZURE_B2C_AUTHORITY=https://nexttechuit.b2clogin.com/nexttechuit.onmicrosoft.com/B2C_1_SignInSignUp/v2.0/

# Azure B2C known authority (domain only)
AZURE_B2C_KNOWN_AUTHORITY=nexttechuit.b2clogin.com

# Post-login redirect URI (defaults to CLIENT_URL if not set)
AZURE_B2C_REDIRECT_URI=http://localhost:4200

# Post-logout redirect URI (defaults to CLIENT_URL if not set)
AZURE_B2C_POST_LOGOUT_REDIRECT_URI=http://localhost:4200


