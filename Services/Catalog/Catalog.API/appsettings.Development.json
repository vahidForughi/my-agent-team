{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AWS": {
    "S3": {
      "BucketName": "ecommerce-product-images",
      "Region": "us-east-1",
      "ImagePrefix": "products/",
      "ServiceUrl": "http://localstack:4566",
      "UsePathStyle": true
    }
  },
  "USE_LOCALSTACK": true,
  "ImageSettings": {
    "MaxFileSizeInMB": 5,
    "AllowedExtensions": [".png", ".jpg", ".jpeg", ".webp"]
  }
}
