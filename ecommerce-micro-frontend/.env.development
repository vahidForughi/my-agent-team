# API Configuration
NX_API_BASE_URL=http://localhost:8010
NX_API_TIMEOUT=30000

# Mock Data Strategy
# Set to 'true' to use mock data instead of real API calls
# Set to 'false' to use real backend APIs
NX_USE_MOCK_DATA=false

# Feature Flags
NX_ENABLE_AUTHENTICATION=true
NX_ENABLE_DISCOUNT_SERVICE=true
NX_ENABLE_ORDER_TRACKING=true

# Logging
NX_LOG_LEVEL=debug
NX_ENABLE_API_LOGGING=true
